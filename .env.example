# ML-WAF Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# CrowdSec CTI API (free tier available at https://app.crowdsec.net/)
# Leave blank to use offline blocklist
CROWDSEC_API_KEY=

# File Upload Security
MAX_FILE_SIZE_MB=10

# Model paths (auto-populated by train.py)
MODEL_PATH=models/waf_model.pkl
METRICS_PATH=models/metrics.json

# CSIC 2010 Dataset paths (optional — if you have the real dataset)
# Download from http://www.isi.csic.es/dataset/
CSIC_NORMAL_PATH=data/normalTrafficTraining.txt
CSIC_ATTACK_PATH=data/anomalousTrafficTest.txt
